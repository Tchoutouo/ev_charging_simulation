@startuml 04_Architecture_Globale

skinparam backgroundColor #1E1E2E
skinparam componentBackgroundColor #2A2A3E
skinparam componentBorderColor #7C7CFF
skinparam componentFontColor #E0E0FF
skinparam packageBackgroundColor #252540
skinparam packageBorderColor #5555AA
skinparam packageFontColor #CCCCFF
skinparam arrowColor #7C7CFF
skinparam arrowFontColor #AAAAFF
skinparam databaseBackgroundColor #2A3A2A
skinparam databaseBorderColor #44AA44
skinparam noteBackgroundColor #2E2E4E
skinparam noteBorderColor #5555AA

title Architecture Globale du Modèle SMA — EV Charging Simulation

' ===================== ENTRÉES =====================
package "Données d'entrée (GIS)" as INPUT #1A2A1A {
    database "roads.shp\n(Shapefile routier)" as SHP
    component "roads.dbf\n(attributs)" as DBF
    component "roads.prj\n(projection CRS)" as PRJ
}

' ===================== COUCHE ENVIRONNEMENT =====================
package "Couche Environnement — global{}" as ENV #1A1A3A {
    component "Graphe routier\n(as_edge_graph)" as GRAPH
    component "Paramètres globaux\n(step, thresholds, etc.)" as PARAMS
    component "Monitoring\n(breakdowns, charges, km)" as MONITOR
    component "Algorithme grille\n(placement stations)" as GRID
}

' ===================== COUCHE AGENTS =====================
package "Couche Agents (Espèces GAMA)" as AGENTS #2A1A3A {

    package "road (GIS)" as ROAD_PKG #252535 {
        component "road\n(segments routiers)" as ROAD_AGENT
    }

    package "charging_station" as STATION_PKG #252535 {
        component "charging_station\nFIFO Queue\nCC-CV" as STATION_AGENT
    }

    package "vehicle (skill: moving)" as VEHICLE_PKG #252535 {
        component "FSM\n(driving/searching\nqueuing/charging/broken)" as FSM
        component "Routage Dijkstra\n(do goto)" as ROUTER
        component "WSM Station\nSelector" as WSM
        component "Énergie kWh/km\n& SoH Dégradation" as ENERGY
        component "Stuck Detection\n(stuck_counter)" as STUCK
    }
}

' ===================== COUCHE SORTIE =====================
package "Couche Visualisation & Sortie" as OUTPUT #2A1A1A {
    component "Carte GIS OpenGL\n(road + station + vehicle)" as MAP
    component "Graphiques temps réel\n(états, batterie, SoH, occ.)" as CHARTS
    component "Moniteurs\n(KPIs simulation)" as KPIS
    component "Batch Results\n(Grid Search)" as BATCH
}

' ===================== RELATIONS =====================

SHP    --> GRAPH   : chargement shapefile
DBF    --> GRAPH
PRJ    --> GRAPH
GRID   --> STATION_AGENT : placement optimal
PARAMS --> FSM
PARAMS --> ENERGY
PARAMS --> STATION_AGENT

GRAPH  --> ROUTER : road_network partagé
ROUTER --> FSM    : do goto()

FSM    --> ENERGY  : consume_energy_for()
FSM    --> WSM     : select_best_station()
FSM    --> STUCK   : stuck_counter
WSM    --> STATION_AGENT : query (dist, queue)
STATION_AGENT --> FSM  : start_charging() / release_vehicle()

FSM    --> MONITOR : total_breakdowns++\ntotal_charges++
ENERGY --> MONITOR : total_distance_km++

MAP    <-- ROAD_AGENT
MAP    <-- STATION_AGENT
MAP    <-- FSM
CHARTS <-- MONITOR
KPIS   <-- MONITOR
BATCH  <-- MONITOR

note bottom of AGENTS
  <b>Algorithmes implémentés :</b>
  1. as_edge_graph → Graphe topologique GIS
  2. Dijkstra → Routage (do goto)
  3. WSM → Sélection station multi-critères
  4. Ratio α/β → Adaptation urgence batterie
  5. FSM → Contrôle comportement véhicule
  6. FIFO → Gestion des files d'attente
  7. Grille → Placement spatial des stations
  8. kWh/km → Consommation réaliste
  9. CC-CV → Courbe de recharge Li-ion
  10. SoH → Dégradation batterie par km
  11. Grid Search → Exploration batch
end note

@enduml

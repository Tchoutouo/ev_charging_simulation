@startuml 06_Activite_Vehicule

skinparam backgroundColor #1E1E2E
skinparam ActivityBackgroundColor #2A2A3E
skinparam ActivityBorderColor #7C7CFF
skinparam ActivityFontColor #E0E0FF
skinparam ArrowColor #7C7CFF
skinparam ArrowFontColor #AAAAFF
skinparam DiamondBackgroundColor #3A2A5A
skinparam DiamondBorderColor #7C7CFF
skinparam NoteBackgroundColor #2E2E4E
skinparam NoteBorderColor #5555AA
skinparam NoteFontColor #CCCCFF

title Diagramme d'Activités — Comportement d'un Véhicule (1 cycle GAMA)

start
note right : **1 cycle = 30 secondes simulées**

' ===== DISPATCH FSM =====
if (state == ?) then
    split
        -[#00CC88]-> "driving";
    split again
        -[#FFAA00]-> "searching";
    split again
        -[#8844FF]-> "queuing";
    split again
        -[#00AACC]-> "charging";
    split again
        -[#FF4444]-> "broken";
    end split
endif

' ===== DRIVING =====
if (state = "driving") then (Oui)
    if (battery ≤ 0 ?) then (Oui)
        :breakdown()\n[broken++, cleanup];
        stop
    endif
    if (battery < threshold ?) then (Oui)
        :state ← "searching"\ntarget_point ← nil;
        stop
    endif
    if (target_point = nil ?) then (Oui)
        :target_point ← random road point\nstuck_counter ← 0;
    endif
    :prev_loc ← location\ndo goto(target_point, road_network)\n**[Dijkstra]**;
    :dist_moved ← dist(location, prev_loc)\nconsume_energy_for(dist_moved)\n**[kWh/km model] + SoH update**;
    if (dist_moved < 1m AND dist_to_target > threshold) then (Bloqué)
        :stuck_counter++;
        if (stuck_counter ≥ max_stuck_cycles) then (Oui)
            :target_point ← nil\nstuck_counter ← 0;
        endif
    else (Normal)
        :stuck_counter ← 0;
        if (dist_to_target < arrival_threshold) then (Arrivé)
            :target_point ← nil;
        endif
    endif
    stop
endif

' ===== SEARCHING =====
if (state = "searching") then (Oui)
    if (battery ≤ 0 ?) then (Oui)
        :breakdown();
        stop
    endif
    :best ← select_best_station()\n**[WSM : α·dist + β·queue]**;
    if (best = nil ?) then (Oui)
        :Déplacement aléatoire\ndétection de blocage (stuck);
        stop
    endif
    :target_station ← best\nreached_station ← false\nstuck_counter ← 0\nstate ← "queuing";
    stop
endif

' ===== QUEUING =====
if (state = "queuing") then (Oui)
    if (battery ≤ 0 ?) then (Oui)
        :Quitter la file\nbreakdown();
        stop
    endif
    if (target_station = nil ?) then (Oui)
        :state ← "searching";
        stop
    endif
    if (!reached_station AND dist > threshold) then (En route)
        :do goto(station.location, road_network)\n**[Dijkstra]**\nconsume_energy_for()\nstuck detection;
        stop
    else (Arrivé)
        :reached_station ← true\nstuck_counter ← 0;
        if (self in queue ?) then (Oui)
            :Attendre (FIFO actif);
            stop
        endif
        if (station.is_full() ?) then (Oui)
            :add_to_queue(self)\n**[FIFO]**\nwaiting_time_start ← cycle;
        else (Non)
            :occupied_slots++\nstate ← "charging";
        endif
        stop
    endif
endif

' ===== CHARGING =====
if (state = "charging") then (Oui)
    if (target_station = nil ?) then (Oui)
        :state ← "driving" [guard];
        stop
    endif
    if (battery < 80%) then (Phase CC)
        :P = charging_power_kw\n(pleine puissance);
    else (Phase CV)
        :soc_factor = 1 - (soc-80)/20 × 0.9\nP = charging_power_kw × max(0.1, soc_factor)\n**[CC-CV Li-ion]**;
    endif
    :energy = P × (step/3600)\nbattery += energy/capacité × 100;
    if (battery ≥ SoH × 95%) then (Rechargé)
        :release_vehicle(self) → station\n[start_charging() pour FIFO\ntarget_station ← nil\nstate ← "driving"];
    endif
    stop
endif

' ===== BROKEN =====
if (state = "broken") then (Oui)
    if (breakdown_cycle = 0) then
        :breakdown_cycle ← cycle;
    endif
    note right : Clignotement visuel :\n(cycle mod 10) < 5
    if (cycle - breakdown_cycle ≥ N) then (Récupéré)
        :battery ← 25%\nstuck_counter ← 0\ntotal_recoveries++\nstate ← "searching";
    else (Attente)
        :Continuer à attendre;
    endif
    stop
endif

@enduml

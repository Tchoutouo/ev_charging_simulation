@startuml 06_Activite_Vehicule

skinparam backgroundColor #1E1E2E
skinparam ActivityBackgroundColor #2A2A3E
skinparam ActivityBorderColor #7C7CFF
skinparam ActivityFontColor #E0E0FF
skinparam ArrowColor #7C7CFF
skinparam ArrowFontColor #AAAAFF
skinparam DiamondBackgroundColor #3A2A5A
skinparam DiamondBorderColor #7C7CFF
skinparam NoteBackgroundColor #2E2E4E
skinparam NoteBorderColor #5555AA
skinparam NoteFontColor #CCCCFF

title Diagramme d'Activités — Comportement d'un Véhicule (1 cycle)

start
note right : cycle évalué avec **adapt_to_environment()**

' ===== DISPATCH FSM =====
if (state == ?) then
    split
        -[#00CC88]-> "driving";
    split again
        -[#FFAA00]-> "searching";
    split again
        -[#8844FF]-> "queuing";
    split again
        -[#00AACC]-> "charging";
    split again
        -[#95A5A6]-> "parked/\ngoing_home/\nsleeping";
    split again
        -[#FF4444]-> "broken";
    end split
endif

' ===== DRIVING =====
if (state = "driving") then (Oui)
    if (battery ≤ 0 ?) then (Oui)
        :breakdown();
        stop
    endif
    
    if (proba aller dormir / proba se garer ?) then (Oui)
        :state ← "going_home" / "parked";
        stop
    endif

    if (battery < threshold ou trajet instable ?) then (Oui)
        :state ← "searching"\ntarget_point ← nil;
        stop
    endif
    
    if (target_point = nil ?) then (Oui)
        :target_point ← random road point;
    endif
    
    :do goto(target_point) **[Dijkstra]**;
    :consume_energy_for();
    
    if (Stuck block > limites) then (Oui)
        :nouveau target_point;
    endif
    stop
endif

' ===== SEARCHING =====
if (state = "searching") then (Oui)
    if (battery ≤ 0 ?) then (Oui)
        :breakdown();
        stop
    endif
    :best ← select_best_station()\n**[WSM : α·dist + β·queue]**;
    if (best != nil ?) then (Oui)
        :target_station ← best\nstate ← "queuing";
    endif
    stop
endif

' ===== QUEUING =====
if (state = "queuing") then (Oui)
    if (dist à station > threshold) then (En route)
        :do goto(station.location)\nconsume_energy_for();
        stop
    else (Arrivé)
        if (station.is_full() ?) then (Oui)
            :add_to_queue(self)\nAttente **[FIFO]**;
        else (Non)
            :occupied_slots++\nstate ← "charging";
        endif
        stop
    endif
endif

' ===== CHARGING =====
if (state = "charging") then (Oui)
    :Courbe de charge CC/CV\nbattery += energy_gained;
    if (battery ≥ SoH × 95%) then (Rechargé)
        :release_vehicle()\nstate ← "driving";
    endif
    stop
endif

' ===== BROKEN =====
if (state = "broken") then (Oui)
    :Attendre l'arrivée du\nTechnicien (is_getting_repaired);
    note right : Le technicien gère le\nretour à l'état searching
    stop
endif

' ===== PARKED / GOING_HOME / SLEEPING =====
if (state = "parked / going_home / sleeping") then (Oui)
    :Gestion probabiliste du réveil;
    :Déplacement vers home_location (si going_home);
    stop
endif

@enduml

@startuml 02_FSM_Vehicule

skinparam backgroundColor #1E1E2E
skinparam StateFontColor #E0E0FF
skinparam StateBackgroundColor #2A2A3E
skinparam StateBorderColor #7C7CFF
skinparam StateStartColor #00CC88
skinparam StateEndColor #FF4444
skinparam ArrowFontColor #AAAAFF
skinparam ArrowColor #7C7CFF
skinparam NoteBackgroundColor #2E2E4E
skinparam NoteBorderColor #5555AA
skinparam NoteFontColor #CCCCFF

title Diagramme d'États-Transitions (FSM) — Espèce vehicle

[*] --> driving : <<init>>\nbattery = rnd(40%, 100%)

' ===== ÉTAT : driving =====
state "🚗 driving" as driving #2A4A2A {
    driving : Déplacement aléatoire\nsur le réseau routier\nAlgorithme : Dijkstra (do goto)
}

' ===== ÉTAT : searching =====
state "🔍 searching" as searching #4A3A1A {
    searching : Sélection de la meilleure\nstation de recharge\nAlgorithme : WSM pondéré (α/β)
}

' ===== ÉTAT : queuing =====
state "⏳ queuing" as queuing #3A2A4A {
    queuing : Navigation vers la station\npuis attente en file FIFO\nAlgorithme : Dijkstra + FIFO
}

' ===== ÉTAT : charging =====
state "⚡ charging" as charging #1A3A3A {
    charging : Recharge à la borne\nAlgorithme : Courbe CC-CV\n(Constant Current / Constant Voltage)
}

' ===== ÉTAT : broken =====
state "💥 broken" as broken #4A1A1A {
    broken : Véhicule en panne\nClignotement visuel\nAttente dépannage (N cycles)
}

' ===== TRANSITIONS =====
driving    --> searching  : battery < battery_threshold (25%)
driving    --> broken     : battery = 0
searching  --> queuing    : station trouvée (WSM)
searching  --> broken     : battery = 0
queuing    --> charging   : arrivé à station\n& place disponible (FIFO)
queuing    --> broken     : battery = 0 en route
charging   --> driving    : battery ≥ SoH × 95%\n[release_vehicle()]
broken     --> searching  : après N cycles\n[dépannage: battery=25%]
driving    --> driving    : target_point atteint\n→ nouvelle destination

' ===== NOTES =====
note right of driving
  <b>Stuck detection :</b>
  Si dist_moved < 1m
  pendant max_stuck_cycles = 3
  → Nouvelle cible aléatoire
end note

note right of queuing
  <b>Arrived condition :</b>
  dist_to_station < arrival_threshold
  (100 m par défaut)
  <i>+ flag reached_station</i>
end note

note left of charging
  <b>Phase CC</b> (0→80%) : 22 kW
  <b>Phase CV</b> (80→100%) :
  puissance × (1 - (soc-80)/20 × 0.9)
  Dégradation SoH : -0.5%/1000km
end note

note left of broken
  <b>breakdown_recovery_cycles</b>
  = 100 cycles (~50 min sim.)
  Recharge urgence → 25%
  puis retour à "searching"
end note

@enduml

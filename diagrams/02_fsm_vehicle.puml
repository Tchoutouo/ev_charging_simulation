@startuml 02_FSM_Vehicule

skinparam backgroundColor #1E1E2E
skinparam StateFontColor #E0E0FF
skinparam StateBackgroundColor #2A2A3E
skinparam StateBorderColor #7C7CFF
skinparam StateStartColor #00CC88
skinparam StateEndColor #FF4444
skinparam ArrowFontColor #AAAAFF
skinparam ArrowColor #7C7CFF
skinparam NoteBackgroundColor #2E2E4E
skinparam NoteBorderColor #5555AA
skinparam NoteFontColor #CCCCFF

title Diagramme d'États-Transitions (FSM) — Espèce vehicle

[*] --> driving : <<init>>\nbattery = rnd(10%, 100%)

' ===== ÉTATS PRINCIPAUX =====
state "🚗 driving" as driving #2A4A2A {
    driving : Déplacement sur le réseau\nAlgorithme : Dijkstra\nRisque de parking en journée
}

state "🔍 searching" as searching #4A3A1A {
    searching : Sélection de la meilleure station\nAlgorithme : WSM pondéré (α/β/γ)
}

state "⏳ queuing" as queuing #3A2A4A {
    queuing : Navigation vers station\n+ Attente en file FIFO
}

state "⚡ charging" as charging #1A3A3A {
    charging : Recharge (Courbes CC-CV)
}

state "💥 broken" as broken #4A1A1A {
    broken : Clignotement visuel\nAttente intervention Technicien
}

' ===== NOUVEAUX ÉTATS (Cycle 24h & Profils) =====
state "🅿️ parked" as parked #2C3E50 {
    parked : À l'arrêt (Travail, Courses)\n(Uniquement pour profil 'personal')
}

state "🏠 going_home" as going_home #34495E {
    going_home : Retour au domicile\nDéclenché le soir ou fins de shift
}

state "💤 sleeping" as sleeping #1A252F {
    sleeping : Garé à la maison\nRéveil stochastique le matin
}

' ===== TRANSITIONS =====
driving    --> searching  : battery < seuil ou anticipation
driving    --> broken     : battery = 0
driving    --> parked     : proba aléatoire (en journée)
driving    --> going_home : proba (Nuit/Fin de shift)

parked     --> driving    : timeout expire
parked     --> searching  : battery critique
parked     --> going_home : proba (Heure de Pointe / Nuit)

going_home --> sleeping   : home_location atteint
going_home --> searching  : battery critique avant d'arriver

sleeping   --> driving    : proba (au réveil / début de shift)

searching  --> queuing    : station trouvée (WSM)
searching  --> broken     : battery = 0
queuing    --> charging   : place disponible (FIFO)
queuing    --> broken     : battery = 0 en route
charging   --> driving    : battery ≥ SoH × 95%
broken     --> searching  : réparation par Technicien

driving    --> driving    : target_point atteint → target=nil

' ===== NOTES COMPLÉMENTAIRES =====
note left of going_home
  <b>Transition stochastique</b>
  Les véhicules (selon profil is_nocturnal) 
  décident de rentrer progressivement.
  Pas de hard-limit (pas tous à 19h).
end note

note right of charging
  <b>CC-CV & Smart Grid</b>
  Puissance partagée à la station.
  Dégradation batterie : SoH
end note

note right of broken
  <b>Dépannage par Techniciens</b>
  (Nécessite patrouille et 100 cycles 
  de temps de réparation in situ)
end note

@enduml
